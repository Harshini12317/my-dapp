# Public WalletConnect project ID (required for RainbowKit WalletConnect integration)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional app name used in wallet dialogs
NEXT_PUBLIC_APP_NAME=TechiesApp

# Optional default contract address for frontend (override in UI)
NEXT_PUBLIC_DEFAULT_ERC721_ADDRESS=0xe2a8cd01354ecc63a8341a849e9b89f14ff9f08f

# Example analytics or monitoring keys
NEXT_PUBLIC_SENTRY_DSN=

# Optional wallet auth nonce expiration (seconds)
NEXT_PUBLIC_WALLET_AUTH_NONCE_TTL=300
